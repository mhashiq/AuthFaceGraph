# ============================================================
# AuthBrain AI Face Analysis Engine — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME="AuthBrain AI Face Analysis Engine"
APP_VERSION="1.0.0"
ENVIRONMENT=development        # development | production | testing
DEBUG=false
LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database (PostgreSQL) ───────────────────────────────────
POSTGRES_USER=authbrain
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=authbrain_db

# ── Redis (caching, session store) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_secure_random_64_char_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MediaPipe Model ─────────────────────────────────────────
# Download: make download-models
FACE_LANDMARKER_MODEL_PATH=models/face_landmarker.task
MAX_NUM_FACES=4
MIN_FACE_DETECTION_CONFIDENCE=0.7
MIN_FACE_PRESENCE_CONFIDENCE=0.7
MIN_TRACKING_CONFIDENCE=0.5

# ── Eye Analysis ────────────────────────────────────────────
EAR_BLINK_THRESHOLD=0.25
EAR_BLINK_CONSEC_FRAMES=3
EAR_CLOSURE_THRESHOLD=0.2

# ── Mouth Analysis ──────────────────────────────────────────
MAR_YAWN_THRESHOLD=0.6
MAR_YAWN_CONSEC_FRAMES=15

# ── Performance ─────────────────────────────────────────────
TARGET_FPS=30
FRAME_QUEUE_SIZE=5
JPEG_QUALITY=80

# ── Storage ─────────────────────────────────────────────────
PERSIST_ALL_FRAMES=false      # Set true only in research mode
PERSIST_SESSION_SUMMARY=true
SESSION_TTL_SECONDS=3600

# ── GPU (Optional) ──────────────────────────────────────────
# Leave blank for auto-detection (CPU fallback if no GPU)
# CUDA_VISIBLE_DEVICES=0
